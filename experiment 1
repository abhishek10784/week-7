#include <stdio.h>
#include <string.h>

int main() {
char s1[100], s2[100], s3[100];
printf("25331A05H2");
printf("\nEnter first string: ");
scanf("%s", s1);
printf("Enter second string: ");
scanf("%s", s2);
printf("Length of s1 = %lu\n", strlen(s1));
strcpy(s3, s1);
printf("Copied string = %s\n", s3);
strcat(s3, s2);
printf("Concatenated = %s\n", s3);
printf("Compare result = %d\n", strcmp(s1, s2));
return 0;
}

